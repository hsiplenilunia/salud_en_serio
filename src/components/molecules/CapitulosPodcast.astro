---
/**
 * Props
 * chapters: Array<{
 *   image: string;
 *   alt?: string;
 *   spotifyUrl?: string;
 * }>
 */

const { chapters = [] }: {
  chapters?: Array<{
    image: string;
    alt?: string;
    title?: string;
    subtitle?: string;
    label?: string;
    spotifyUrl?: string;
  }>;
} = Astro.props;

const normalizeSpotifyUrl = (url?: string) => {
  if (!url) return undefined;
  const trimmed = url.trim();
  return trimmed.length > 0 ? trimmed : undefined;
};

const getLabel = (label?: string) => label ?? "Episodio Inaugural";

---

<section
  id="capitulos"
  class="w-screen bg-bg-gray px-6 pt-[150px] pb-12"
>
    <div class="mb-8 flex flex-col gap-2">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-[0.36em] text-brand-purple">Podcast</p>
          <h2 class="mt-3 text-3xl font-semibold text-slate-900">Capítulos</h2>
        </div>
        <p class="hidden text-sm text-slate-500 md:flex items-center gap-2">
          Desliza para ver más
          <span class="inline-flex h-[1px] w-10 bg-slate-300" />
        </p>
      </div>
      <p class="text-sm text-slate-500 md:hidden">Desliza para ver más episodios →</p>
    </div>

    <div class="overflow-x-auto pb-6">
      <div class="flex gap-6 px-2 snap-x snap-mandatory">
        {chapters.map((chapter) => {
          const spotifyUrl = normalizeSpotifyUrl(chapter.spotifyUrl);
          const title = chapter.title ?? "Capítulo";

          return (
            <article class="snap-start min-w-[280px] max-w-[280px] rounded-[32px] bg-white p-5 shadow-xl shadow-slate-300/50 ring-1 ring-slate-200 sm:min-w-[320px] sm:max-w-[320px]">
              <div class="mb-4">
                <span class="inline-flex rounded-full bg-navy px-3 py-1 text-[10px] font-bold uppercase tracking-[0.28em] text-white">
                  {getLabel(chapter.label)}
                </span>
                <h3 class="mt-4 text-lg font-semibold leading-6 text-slate-900">{title}</h3>
                {chapter.subtitle ? (
                  <p class="mt-2 text-sm leading-5 text-slate-500">{chapter.subtitle}</p>
                ) : null}
              </div>

              {spotifyUrl ? (
                <div class="overflow-hidden rounded-[28px] bg-black">
                  <iframe
                    data-testid="embed-iframe"
                    style="border-radius:12px"
                    src={spotifyUrl}
                    width="100%"
                    height="352"
                    frameborder="0"
                    allowfullscreen=""
                    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                    loading="lazy"
                    title={`Spotify episodio: ${title}`}
                    class="block"
                  />
                </div>
              ) : (
                <div class="flex h-[352px] items-center justify-center rounded-[28px] bg-slate-100 text-sm text-slate-500">
                  Sin enlace disponible
                </div>
              )}
            </article>
          );
        })}
      </div>
    </div>
</section>